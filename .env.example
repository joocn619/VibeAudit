# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# GitHub App (for repository scanning & PR creation)
GITHUB_APP_ID=123456
GITHUB_APP_SLUG=vibeaudit
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
GITHUB_APP_WEBHOOK_SECRET=your-webhook-secret
GITHUB_CLIENT_ID=Iv1.yourclientid
GITHUB_CLIENT_SECRET=yourclientsecret

# AI (Claude API for plain-English report & fix generation)
ANTHROPIC_API_KEY=sk-ant-api03-...

# Stripe Billing
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_PRO_MONTHLY_PRICE_ID=price_...
STRIPE_AGENCY_MONTHLY_PRICE_ID=price_...

# Email & Notifications
RESEND_API_KEY=re_...

# Analytics & Monitoring
NEXT_PUBLIC_POSTHOG_KEY=phc_...
SENTRY_DSN=https://...@sentry.io/...

# App & Worker URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000
SCAN_WORKER_URL=http://localhost:8080

# Demo mode (walkthrough recordings ONLY). When "true" AND not running in
# production, the dashboard is viewable without login and shows demo data.
# Ignored in production builds, so it is never an auth bypass. Leave unset.
NEXT_PUBLIC_DEMO_MODE=false
